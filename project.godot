; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="popopcorn"
run/main_scene="res://scenes/menu/intro_cubyt.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Transicion="*res://scenes/ui/transicion.tscn"
SistemaNombreCine="*res://scripts/sistema_nombre_cine.gd"
GestorInicio="*res://scripts/gestor_inicio.gd"
GestorMenus="*res://scripts/gestor_menus.gd"
GestorGameplay="*res://scripts/gestor_gameplay.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

interactuar={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":69,"key_label":0,"unicode":101,"location":0,"echo":false,"script":null)
]
}
toggle_flashlight={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":70,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]
rendering_device/driver.windows="d3d12"

[Lights and Shadows - ULTRA QUALITY]
; Directional Light (Sun) Shadows - INCREASED RESOLUTION
lights_and_shadows/directional_shadow/size=8192
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=3
lights_and_shadows/directional_shadow/16_bits=true

; Positional Lights (Point/Spot) Shadows - INCREASED QUALITY
lights_and_shadows/positional_shadow/atlas_size=8192
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
lights_and_shadows/positional_shadow/16_bits=true

; Shadow Blending - SMOOTHER TRANSITIONS
lights_and_shadows/shadow_blur=1.5

; Anti-Aliasing - SMOOTHER EDGES
anti_aliasing/quality/msaa_3d=3
anti_aliasing/quality/use_taa=true
anti_aliasing/quality/use_debanding=true

; Environment
environment/defaults/default_clear_color=Color(0.05, 0.03, 0.03, 1)
occlusion_culling/use_occlusion_culling=true

; Texture Quality - SHARPER TEXTURES
textures/decals/filter=5
textures/light_projectors/filter=5

; Max Lights Visible - MORE DYNAMIC LIGHTS
lights_and_shadows/max_lights_per_object=32
