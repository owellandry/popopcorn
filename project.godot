; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[Lights and Shadows - ULTRA QUALITY]

lights_and_shadows/directional_shadow/size=4096
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=1
lights_and_shadows/directional_shadow/16_bits=false
lights_and_shadows/positional_shadow/atlas_size=4096
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=1
lights_and_shadows/positional_shadow/16_bits=false
lights_and_shadows/shadow_blur=1.0
anti_aliasing/quality/msaa_3d=0
anti_aliasing/quality/use_taa=true
anti_aliasing/quality/use_debanding=true
environment/defaults/default_clear_color=Color(0.05, 0.03, 0.03, 1)
occlusion_culling/use_occlusion_culling=true
textures/decals/filter=2
textures/light_projectors/filter=2
lights_and_shadows/max_lights_per_object=8

[application]

config/name="popopcorn"
run/main_scene="res://scenes/menu/intro_cubyt.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Transicion="*res://scenes/ui/transicion.tscn"
SistemaNombreCine="*res://scripts/autoloads/sistema_nombre_cine.gd"
GestorInicio="*res://scripts/autoloads/gestor_inicio.gd"
GestorMenus="*res://scripts/autoloads/gestor_menus.gd"
GestorGameplay="*res://scripts/autoloads/gestor_gameplay.gd"
GestorVisitantes="*res://scripts/autoloads/gestor_visitantes.gd"
GestorInventario="*res://scripts/autoloads/gestor_inventario.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

